# ---------------------------------------------------------------------------
# Copy this file to ".env" and paste your key. The .env file is gitignored
# and is read ONLY by the Express server (server.js) at runtime.
#
# Because this variable has NO "VITE_" prefix, Vite will never expose it to
# the browser bundle. The key stays on the server side. Do not rename it to
# VITE_GEMINI_API_KEY unless you intend to expose it publicly.
# ---------------------------------------------------------------------------

# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# Optional: which Gemini model to use (defaults to gemini-2.0-flash)
GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# OpenRouter (https://openrouter.ai) — alternative LLM provider, a unified
# gateway to many models. Get a key at https://openrouter.ai/keys . No "VITE_"
# prefix, so it stays server-side only and is never bundled into the browser.
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Any model slug from https://openrouter.ai/models
OPENROUTER_MODEL=google/gemini-2.5-flash

# Optional: port for the local proxy server
PORT=3001

# ---------------------------------------------------------------------------
# Persistence (Supabase Postgres) — optional.
# Stores every conversation + generated draft so the "Saved Projects" page can
# list them. If this is left blank the app still works; it just won't persist.
#
# Use the Supabase "Transaction pooler" connection string (Project →
# Settings → Database → Connection string → "Transaction pooler"). It is the
# serverless-safe one. Replace [YOUR-PASSWORD] with your DB password.
# Like GEMINI_API_KEY it has NO "VITE_" prefix, so it stays server-side only.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres
